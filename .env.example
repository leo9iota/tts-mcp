# Text-to-Speech API Keys (Uncomment and fill to activate providers in the MCP Inspector)

# ElevenLabs (Industry Standard)
# ELEVENLABS_API_KEY="{{YOUR_API_KEY_HERE}}"

# OpenAI (General Voice)
# OPENAI_API_KEY="{{YOUR_API_KEY_HERE}}"

# Fish Audio (Voice Cloning)
# FISH_AUDIO_API_KEY="{{YOUR_API_KEY_HERE}}"

# Neets (Fast/Cheap)
# NEETS_API_KEY="{{YOUR_API_KEY_HERE}}"

# Cartesia (Ultra-low Latency)
# CARTESIA_API_KEY="{{YOUR_API_KEY_HERE}}"

# PlayHT (Expressive Voices)
# PLAYHT_API_KEY="{{YOUR_API_KEY_HERE}}"
# PLAYHT_USER_ID="{{YOUR_USER_ID_HERE}}"

# Azure Cognitive Services (Enterprise Neural)
# AZURE_SPEECH_KEY="{{YOUR_API_KEY_HERE}}"
# AZURE_SPEECH_REGION="{{YOUR_REGION_HERE}}"

# Local Open-Source Endpoint (Kokoro, XTTS, Piper using OpenAI-compatible structure)
# LOCAL_TTS_ENDPOINT="http://localhost:8080/v1/audio/speech"
# LOCAL_TTS_API_KEY="{{YOUR_OPTIONAL_API_KEY_HERE}}"
